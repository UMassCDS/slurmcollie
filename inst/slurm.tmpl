## Slurm template for launching batch jobs from RStudio on Unity
## Uses r-rocker-ml-verse/4.4.3_cuda12.8.1+apptainer for GPU and CPU jobs
## 03 Mar 2026

#!/bin/bash

## Relative paths are not handled well by Slurm
<%
log.file = fs::path_expand(log.file)
-%>

#SBATCH --job-name=<%= job.name %>
#SBATCH --output=<%= log.file %>
#SBATCH --error=<%= log.file %>
#SBATCH --time=<%= resources$walltime %>
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=<%= resources$ncpus %>
#SBATCH --mem=<%= resources$memory %>G                ## memory is reported in GB, not MB
#SBATCH --export=None
#SBATCH --nodes=1                                     ## avoid error about not specifying --nodes=1
<%
use_gpu <- !is.null(resources$ngpus) && resources$ngpus > 0
if (use_gpu) {
   gres <- if (!is.null(resources$gpu_type) && nzchar(resources$gpu_type))
      paste0('gpu:', resources$gpu_type, ':', resources$ngpus)
   else
      paste0('gpu:', resources$ngpus)
}
-%>
<% if (use_gpu) { %>
#SBATCH --gres=<%= gres %>
#SBATCH --partition=<%= if (!is.null(resources$partition.gpu)) resources$partition.gpu else 'gpu-preempt,gpu' %>
<% } else { %>
#SBATCH --partition=<%= if (!is.null(resources$partition.cpu)) resources$partition.cpu else 'cpu-preempt,cpu' %>
<% } %>

##SBATCH --mail-type=END                              ## send an email when job finishes


## Export value of DEBUGME environment var
export DEBUGME=<%= Sys.getenv("DEBUGME") %>

. /etc/profile.d/z00-lmod-profile.sh
module load r-rocker-ml-verse/4.4.3_cuda12.8.1+apptainer

<% if (use_gpu) { %>
echo "Node: $(hostname), GPU: $(nvidia-smi --query-gpu=name,memory.total --format=csv,noheader 2>/dev/null || echo 'unknown')"
<% } else { %>
echo "Node: $(hostname)"
<% } %>

Rscript --no-restore --quiet --no-save \
    -e '.libPaths(c(file.path(path.expand("~"), "R/x86_64-pc-linux-gnu-library/4.4-rocker"), .libPaths()))' \
    -e 'batchtools::doJobCollection("<%= uri %>")'
