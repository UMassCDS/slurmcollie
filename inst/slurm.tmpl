## Slurm template for launching batch jobs from RStudio on Unity
## Thanks to Georgia Stuart!
## You may need to include the following in Override RStudio image location when 
## launching RStudio OnDemand:
##    /modules/admin-resources/ood-dev/unity-r_4.4.0.sif
##
## Note: this script is hardcoded to R 4.4; it'll need updating when going to a newer version
##
## 26 Feb 2026


#!/bin/bash


## Relative paths are not handled well by Slurm
<%
log.file = fs::path_expand(log.file)
-%>

#SBATCH --job-name=<%= job.name %>
#SBATCH --output=<%= log.file %>
#SBATCH --error=<%= log.file %>
#SBATCH --time=<%= resources$walltime %>
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=<%= resources$ncpus %>
#SBATCH --mem=<%= resources$memory %>G                ## memory is reported in GB, not MB
#SBATCH --export=None
#SBATCH --nodes=1                                     ## set minimum nodes to 1 to avoid new error
<%
use_gpu <- !is.null(resources$ngpus) && resources$ngpus > 0
if (use_gpu) {
   gres <- if (!is.null(resources$gpu_type) && nzchar(resources$gpu_type))
      paste0('gpu:', resources$gpu_type, ':', resources$ngpus)
   else
      paste0('gpu:', resources$ngpus)
}
-%>
<% if (use_gpu) { %>
#SBATCH --gres=<%= gres %>
#SBATCH --partition=<%= if (!is.null(resources$partition.gpu)) resources$partition.gpu else 'gpu-preempt,gpu' %>
<% } else { %>
#SBATCH --partition=<%= if (!is.null(resources$partition.cpu)) resources$partition.cpu else 'cpu-preempt,cpu' %>
<% } %>

##SBATCH --mail-type=END                              ## send an email when job finishes


## Export value of DEBUGME environemnt var
export DEBUGME=<%= Sys.getenv("DEBUGME") %>


## Call batchtools inside container
module load apptainer/latest
export APPTAINER_BINDPATH="/run/munge,/var/run/munge,/etc/slurm,/var/spool/slurm/slurmd/conf-cache/slurm.conf,$APPTAINER_BINDPATH"

apptainer exec <%= if (use_gpu) '--nv' else '' %> /modules/admin-resources/ood-dev/unity-r_4.4.0.sif Rscript --no-restore --quiet --no-save -e '.libPaths(c(file.path(path.expand("~"), "R/x86_64-pc-linux-gnu-library/4.4"), .libPaths()))' -e 'batchtools::doJobCollection("<%= uri %>")'
